{
  "rules": [
    { "match": { "tags": ["crash", "outage", "fatal"] },               "species": "anchor" },
    { "match": { "tags": ["abstract", "conclusion"] },                 "species": "anchor" },
    { "match": { "tags": ["error", "bug", "fix"] },                    "species": "sentinel" },
    { "match": { "tags": ["definition", "theorem"] },                  "species": "sentinel" },
    { "match": { "tags": ["constraint", "bound"] },                    "species": "sentinel" },
    { "match": { "tags": ["rule", "convention", "lint", "policy"] },   "species": "sentinel" },
    { "match": { "tags": ["methodology", "comparison"] },              "species": "herald" },
    { "match": { "tags": ["performance"] },                            "species": "herald" },
    { "match": { "tags": ["gotcha"] },                                 "species": "herald" },
    { "match": { "tags": ["results", "findings"] },                    "species": "herald" },
    { "match": { "tags": ["refactor"] },                               "species": "herald" },
    { "match": { "tags": ["release", "deploy", "commit", "ship"] },    "species": "herald" },
    { "match": { "tags": ["caveat"] },                                 "species": "summarizer" },
    { "match": { "tags": ["debug", "monitoring"] },                    "species": "summarizer" },
    { "match": { "tags": ["config", "env", "infra", "docker"] },       "species": "summarizer" },
    { "match": { "tags": ["dependency"] },                             "species": "summarizer" },
    { "match": { "tags": ["summary", "digest", "log"] },               "species": "summarizer" },
    { "match": { "tags": ["experiment", "obsolete"] },                 "species": "spore" },
    { "match": { "tags": ["idea", "draft", "hypothesis", "wip"] },     "species": "spore" },
    { "match": { "tags": ["temporary"] },                              "species": "spore" }
  ],
  "default": "summarizer"
}
